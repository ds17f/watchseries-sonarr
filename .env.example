# Copy this file to `.env` next to docker-compose.yml and edit as needed.

# Host directory that will be bind-mounted as the container's /downloads.
# Point this at the same path Sonarr/Radarr already use as their download
# folder — that way Sonarr's import works with no remote-path mapping.
DOWNLOADS_DIR=./downloads

# Host port the service listens on. Sonarr's qBittorrent download client
# config and Prowlarr's indexer URL both reference this port.
HOST_PORT=8765

# Run the container as this uid/gid (must own / be able to write
# $DOWNLOADS_DIR). Mirror your *arr stack's PUID/PGID — linuxserver
# defaults are 1000/1000; many home-NAS setups use 1000/100.
PUID=1000
PGID=1000

# Timezone for log timestamps and inside-container clock.
TZ=UTC

# Display name in the Torznab capabilities response.
WSG_INDEXER_TITLE=WatchSeries.bar

# Optional. If set, the indexer can resolve tvdbid / imdbid to TMDB IDs and
# do free-text search via the TMDB API. Without it, queries must include
# tmdbid directly (search by name will return no results).
# Get a key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
